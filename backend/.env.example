# ==============================================
# TradingCrypto Backend — Variables de entorno
# ==============================================
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env al repositorio

# ── Servidor ──────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tradingcrypto
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI
DB_SSL=false

# ── Anthropic / Claude ────────────────────────
# Obtené tu API key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZAR_CON_TU_KEY

# ── Binance ───────────────────────────────────
# API key de Binance (sólo requiere permisos de lectura para datos de mercado)
# https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=REEMPLAZAR_CON_TU_BINANCE_API_KEY
BINANCE_API_SECRET=REEMPLAZAR_CON_TU_BINANCE_API_SECRET
# Usar testnet de Binance (true/false)
BINANCE_TESTNET=false

# ── CoinMarketCap ─────────────────────────────
# https://pro.coinmarketcap.com/api/key/
CMC_API_KEY=

# ── Seguridad del webhook ─────────────────────
# Token secreto para validar webhooks de TradingView
# Podés usar cualquier string aleatorio largo
WEBHOOK_SECRET=REEMPLAZAR_CON_UN_TOKEN_SECRETO_LARGO

# ── Rate limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
